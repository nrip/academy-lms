{
    "name": "academy/lms",
    "description": "Academy LMS — Continuing Medical Education platform",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-sodium": "*",
        "laminas/laminas-diactoros": "^3.5",
        "laminas/laminas-httphandlerrunner": "^2.11",
        "league/route": "^7.0",
        "monolog/monolog": "^3.8",
        "php-di/php-di": "^7.0",
        "psr/container": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.75",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5",
        "robmorgan/phinx": "^0.16"
    },
    "autoload": {
        "psr-4": {
            "Academy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Academy\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {}
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "assets:install": "node bin/install-frontend-assets.mjs"
    }
}
