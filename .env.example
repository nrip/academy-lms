APP_NAME=Academy LMS
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

# Comma-separated proxy IPs, or blank to disable trusted-proxy handling
TRUSTED_PROXIES=
FORCE_HTTPS=false

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=academy_lms
DB_USER=academy
DB_PASSWORD=
DB_CHARSET=utf8mb4

LOG_LEVEL=debug
LOG_PATH=storage/logs/app.log

# Session / rate-limit / outbox (WP-01A)
RATE_LIMIT_PEPPER=change-me-in-production
SESSION_COOKIE_SECURE=false
SESSION_ACTIVITY_THROTTLE_SECONDS=300
SESSION_IDLE_SECONDS=1800
SESSION_ABSOLUTE_SECONDS=43200
SESSION_PRIVILEGED_IDLE_SECONDS=900
SESSION_PRIVILEGED_ABSOLUTE_SECONDS=28800
OUTBOX_LEASE_SECONDS=60
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_BACKOFF_BASE_SECONDS=5
OUTBOX_BACKOFF_CAP_SECONDS=3600
# unconfigured | memory (memory only for local/testing)
OUTBOX_TRANSPORT=unconfigured
