APP_NAME=Academy LMS
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

# Comma-separated proxy IPs, or blank to disable trusted-proxy handling
TRUSTED_PROXIES=
FORCE_HTTPS=false

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=academy_lms
DB_USER=academy
DB_PASSWORD=
DB_CHARSET=utf8mb4

LOG_LEVEL=debug
LOG_PATH=storage/logs/app.log

