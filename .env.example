APP_NAME=Academy LMS
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

# Comma-separated proxy IPs, or blank to disable trusted-proxy handling
TRUSTED_PROXIES=
FORCE_HTTPS=false

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=academy_lms
DB_USER=academy
DB_PASSWORD=
DB_CHARSET=utf8mb4

LOG_LEVEL=debug
LOG_PATH=storage/logs/app.log

# Session / rate-limit / outbox (WP-01A)
RATE_LIMIT_PEPPER=change-me-in-production
SESSION_COOKIE_SECURE=false
SESSION_ACTIVITY_THROTTLE_SECONDS=300
SESSION_IDLE_SECONDS=1800
SESSION_ABSOLUTE_SECONDS=43200
SESSION_PRIVILEGED_IDLE_SECONDS=900
SESSION_PRIVILEGED_ABSOLUTE_SECONDS=28800
OUTBOX_LEASE_SECONDS=60
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_BACKOFF_BASE_SECONDS=5
OUTBOX_BACKOFF_CAP_SECONDS=3600
# unconfigured | memory (memory only for local/testing)
OUTBOX_TRANSPORT=unconfigured

# WP-01B-2a notification / verification crypto
TOKEN_PEPPER=change-me-token-pepper
OTP_PEPPER=change-me-otp-pepper-different
# 32-byte key, strict base64
NOTIFICATION_DELIVERY_KEY=
NOTIFICATION_DELIVERY_KEY_PREVIOUS=
NOTIFICATION_DELIVERY_KEY_VERSION=1
TOKEN_CONFIRMATION_CONTEXT_TTL_SECONDS=900
TOKEN_CONFIRMATION_CLEANUP_RETENTION_DAYS=7
TOKEN_CONFIRMATION_CLEANUP_BATCH_SIZE=1000
# recording | local_file | unavailable (recording/local_file forbidden in staging/production)
NOTIFICATION_EMAIL_ADAPTER=
NOTIFICATION_SMS_ADAPTER=
NOTIFICATION_LOCAL_MAIL_PATH=storage/mail

# WP-01B-2b registration legal acceptance versions
TERMS_VERSION=2026-07-22
PRIVACY_VERSION=2026-07-22

# WP-05 payment checkout (Razorpay). Fake gateway only for local|testing|ci.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Empty = default on for testing/ci, off otherwise. Never enable in staging/production.
PAYMENTS_FAKE_GATEWAY=
